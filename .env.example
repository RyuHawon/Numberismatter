# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
# SECRET_KEY 생성: uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
# 배포 시: DEBUG=False, ALLOWED_HOSTS=도메인,서버IP (쉼표 구분)
ALLOWED_HOSTS=
# 배포 시: CSRF_TRUSTED_ORIGINS=http://서버IP (POST 폼 허용)
CSRF_TRUSTED_ORIGINS=

# ── 아래는 Docker(postgres)로 띄울 때만 필요. 로컬 runserver(sqlite)에선 불필요 ──
# DATABASE_URL 없으면 sqlite로 자동 폴백됨.
POSTGRES_DB=numberismatter
POSTGRES_USER=gameuser
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://gameuser:change-me@db:5432/numberismatter
